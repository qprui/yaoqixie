[Unit]
Description=肴柒蟹 API 服务
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/yaoqixie
Environment="PATH=/opt/yaoqixie/venv/bin"
Environment="SECRET_KEY=your-random-secret-key-change-me"
Environment="JWT_SECRET_KEY=your-jwt-secret-key-change-me"
Environment="CORS_ORIGINS=http://localhost:5500,https://yaoqixie.github.io"
ExecStart=/opt/yaoqixie/venv/bin/gunicorn -w 4 -b 127.0.0.1:8000 wsgi:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
